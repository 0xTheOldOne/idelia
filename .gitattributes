# Normalisation des fins de ligne : LF dans le dépôt et à la restitution.
* text=auto eol=lf

# Scripts spécifiques Windows : conserver CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Fichiers binaires : aucune conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.pdf  binary
